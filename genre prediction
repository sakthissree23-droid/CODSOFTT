import pandas as pd
from sklearn.feature_extraction.text import TfidfVectorizer
from sklearn.naive_bayes import MultinomialNB

# Sample dataset
data = {
    "Plot": [
        "A superhero saves the world",
        "A couple falls in love",
        "A ghost haunts a family",
        "A detective solves a murder case",
        "A spaceship travels through space",
        "A group of friends make everyone laugh"
    ],
    "Genre": [
        "Action",
        "Romance",
        "Horror",
        "Crime",
        "Sci-Fi",
        "Comedy"
    ]
}

# Create DataFrame
df = pd.DataFrame(data)

# Convert text into numbers using TF-IDF
vectorizer = TfidfVectorizer()
X = vectorizer.fit_transform(df["Plot"])

# Output labels
y = df["Genre"]

# Train Naive Bayes model
model = MultinomialNB()
model.fit(X, y)

# User input
movie_plot = input("Enter Movie Plot: ")

# Convert input into TF-IDF
movie_vector = vectorizer.transform([movie_plot])

# Predict genre
prediction = model.predict(movie_vector)

print("Predicted Genre:", prediction[0])

